 application "Contest Performance Tracker"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form contest_participation
		{
			displayname = "Contest Participation"
			success message = "Contest Participation Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			contest_name
			(
    			type = text
				displayname = "Contest Name"
	 			row = 1
	 			column = 1   
				width = medium
			)
			platform
			(
				type = radiobuttons
				displayname = "Platform"
				values = {"Codeforces","LeetCode"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			contest_date
			(
    			type = date
				displayname = "Contest Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			start_time
			(
    			type = datetime
				displayname = "Start Time"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			end_time
			(
    			type = datetime
				displayname = "End Time"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			total_time_spent
			(
    			type = time
				displayname = "Total Time Spent"
				timedisplayoptions = "hh:mm:ss" 
	 			row = 1
	 			column = 1   
				width = medium
			)
			problems_attempted
			(
				type = number
				displayname = "Problems Attempted"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			problems_solved
			(
				type = number
				displayname = "Problems Solved"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			submission_status
			(
				type = picklist
				displayname = "Submission Status"
				values = {"Partial","Failed","All Solved"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			participant
			(
    			type = text
				displayname = "Participant"
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
