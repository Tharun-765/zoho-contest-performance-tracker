	reports
	{
		list contest_participation_Report
		{
			displayName = "All Contest Participations"
			show all rows from contest_participation    
			(
				contest_name as "Contest Name"
				platform as "Platform"
				contest_date as "Contest Date"
				start_time as "Start Time"
				end_time as "End Time"
				total_time_spent as "Total Time Spent"
				problems_attempted as "Problems Attempted"
				problems_solved as "Problems Solved"
				submission_status as "Submission Status"
				participant as "Participant"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (submission_status == "All Solved")
				fields = [submission_status]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (submission_status == "Failed")
				fields = [submission_status]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (submission_status == "Partial")
				fields = [submission_status]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban contest_participation_by_submission_status
		{
			displayName = "Submission Statuses"
			show all rows from contest_participation    
			(
				contest_name as "Contest Name"
				platform as "Platform"
				contest_date as "Contest Date"
				start_time as "Start Time"
				end_time as "End Time"
				total_time_spent as "Total Time Spent"
				problems_attempted as "Problems Attempted"
				problems_solved as "Problems Solved"
				submission_status as "Submission Status"
				participant as "Participant"
			)
			options
			(
	 			display field = submission_status
	 		)
		}
		list contest_preparation_plan_Report
		{
			displayName = "All Contest Preparation Plans"
			show all rows from contest_preparation_plan    
			(
				contest_name as "Contest Name"
