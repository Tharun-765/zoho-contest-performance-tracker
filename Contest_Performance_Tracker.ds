	share_settings
	{
			"Data Integrity Specialist"
			{
				name = "Data Integrity Specialist"
				type = Users_Permissions
				permissions = {Chat:false, Predefined:false, ApiAccess:true, PIIAccess:true, ePHIAccess:true}
				description = "Validate and clean incoming contest and performance data from multiple sources \n"
				ModulePermissions
				{
					performance_trend
