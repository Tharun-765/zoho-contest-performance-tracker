				difficulty as "Difficulty"
				study_duration as "Study Duration"
				practice_problems as "Practice Problems"
				status as "Status"
				participant as "Participant"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (difficulty == "Easy")
				fields = [difficulty]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (difficulty == "Expert")
				fields = [difficulty]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (difficulty == "Hard")
				fields = [difficulty]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
				"New Formatting4"
				{
				condition = (difficulty == "Medium")
				fields = [difficulty]
				format = "color:#ffffff;background-color:#3598db;"
				}
			)
		}
		kanban contest_preparation_plan_by_difficulty
		{
			displayName = "Difficulties"
			show all rows from contest_preparation_plan    
			(
				contest_name as "Contest Name"
